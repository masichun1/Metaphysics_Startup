# 小红书项目环境变量
# 复制为 .env 并填入真实值

# --- Anthropic Claude API ---
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxx
ANTHROPIC_DEFAULT_MODEL=claude-sonnet-4-20250514

# --- OpenCLI 配置 ---
OPENCLI_BROWSER_HEADLESS=false
OPENCLI_PROXY_URL=http://user:pass@proxy.example.com:8080
OPENCLI_PROXY_POOL_PATH=config/proxy_pool.txt
OPENCLI_USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36
OPENCLI_PAGE_TIMEOUT_MS=30000
OPENCLI_ACTION_DELAY_MIN_MS=500
OPENCLI_ACTION_DELAY_MAX_MS=5000

# --- 小红书账号 ---
XHS_USERNAME=your_account
XHS_PASSWORD=your_password
XHS_COOKIE_PATH=data/cache/cookies.json

# --- 数据存储 ---
DATA_DB_PATH=data/cache/xhs_data.db

# --- 日志 ---
LOG_LEVEL=INFO
