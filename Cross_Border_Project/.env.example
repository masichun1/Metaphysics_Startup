# ============================================================
# Metaphysics Startup — 跨境项目环境变量配置
# 复制此文件为 .env 并填入真实值
# WARNING: .env 包含敏感信息，切勿提交至 Git！
# ============================================================

# --- Anthropic Claude API ---
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxx
ANTHROPIC_DEFAULT_MODEL=claude-sonnet-4-20250514
ANTHROPIC_MAX_TOKENS_DEFAULT=4096

# --- Shopify ---
SHOPIFY_STORE_DOMAIN=your-store.myshopify.com
SHOPIFY_API_VERSION=2024-01
SHOPIFY_ACCESS_TOKEN=shpat_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Email (Klaviyo SMTP) ---
SMTP_HOST=smtp.klaviyo.com
SMTP_PORT=587
SMTP_USER=your-api-key
SMTP_PASSWORD=your-smtp-password
FROM_EMAIL=support@mysticsanctuary.com
FROM_NAME=Mystic Sanctuary

# --- Twilio (SMS 通知) ---
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_PHONE_NUMBER=+1234567890

# --- 广告平台 API ---
# Meta Ads (Facebook + Instagram)
META_ACCESS_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxx
META_AD_ACCOUNT_ID=act_xxxxxxxxxxxxxxxxx

# Google Ads
GOOGLE_ADS_CLIENT_ID=xxxxxxxxxxxxx
GOOGLE_ADS_CLIENT_SECRET=xxxxxxxxxxxx
GOOGLE_ADS_DEVELOPER_TOKEN=xxxxxxxxxxxx
GOOGLE_ADS_MANAGER_ID=xxx-xxx-xxxx
GOOGLE_ADS_CUSTOMER_ID=xxxxxxxxxx

# TikTok Ads
TIKTOK_ADVERTISER_ID=xxxxxxxxxx
TIKTOK_ACCESS_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Slack 通知 (报表推送) ---
SLACK_BOT_TOKEN=xoxb-xxxxxxxxxxxx-xxxxxxxxxxxxx-xxxxxxxxxxxxxxxxxx
SLACK_REPORT_CHANNEL=#reports

# --- 其他 ---
LOG_LEVEL=INFO
ENVIRONMENT=production
