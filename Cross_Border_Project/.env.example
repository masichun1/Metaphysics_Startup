# ============================================================
# Metaphysics Startup — 跨境项目 (WordPress + WooCommerce)
# 复制为 .env 并填入真实值
# ============================================================

# --- AI API (DeepSeek / Anthropic) ---
ANTHROPIC_API_KEY=sk-your-key
ANTHROPIC_DEFAULT_MODEL=deepseek-chat
ANTHROPIC_MAX_TOKENS_DEFAULT=4096

# --- WordPress 站点 ---
WP_SITE_URL=https://your-site.com
WP_ADMIN_USER=admin
WP_APP_PASSWORD=xxxx xxxx xxxx xxxx xxxx xxxx

# --- WooCommerce REST API ---
WC_CONSUMER_KEY=ck_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
WC_CONSUMER_SECRET=cs_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- SMTP 邮件 ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
FROM_EMAIL=support@mysticsanctuary.com
FROM_NAME=Mystic Sanctuary

# --- 广告平台 ---
META_ACCESS_TOKEN=
META_AD_ACCOUNT_ID=
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_CUSTOMER_ID=
TIKTOK_ACCESS_TOKEN=

# --- Slack ---
SLACK_BOT_TOKEN=
SLACK_REPORT_CHANNEL=#reports

# --- 其他 ---
LOG_LEVEL=INFO
